{
    "name": "jperdior/tenancy-php",
    "description": "Optional multi-tenancy add-on: TenantContext, TenantOwned marker, Doctrine SQLFilter, JWT-claim and subdomain reference resolvers, wired by TenancyBundle. Off by default; opt in per project.",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "jperdior/shared-kernel-php": "*",
        "doctrine/orm": "^3.0",
        "symfony/config": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/http-kernel": "^7.4"
    },
    "require-dev": {
        "doctrine/dbal": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jperdior\\Tenancy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jperdior\\Tenancy\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
