{
  "name": "@jperdior/api-client-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./types": {
      "types": "./src/types.gen.ts",
      "default": "./src/types.gen.ts"
    }
  },
  "scripts": {
    "gen": "openapi-typescript ../../apps/api/openapi.json -o src/types.gen.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "build": "echo 'api-client-ts is source-consumed; nothing to build.'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {},
  "peerDependencies": {
    "openapi-typescript": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "next": "^16.0.0",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.0",
    "eslint": "^9.13.0",
    "vitest": "^2.1.8"
  }
}
