{
    "name": "jperdior/shared-kernel-php",
    "description": "DDD building blocks shared by every PHP app in this monorepo: AggregateRoot, Bus interfaces, value objects, Clock.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "symfony/uid": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Jperdior\\SharedKernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jperdior\\SharedKernel\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
