{
    "name": "jperdior/api",
    "description": "Symfony 7.4 API for jperdior-template. DDD + Hexagonal + CQRS via Messenger; JWT auth; PostgreSQL via Doctrine 3 (XML mapping).",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        { "type": "path", "url": "../../packages/shared-kernel-php" },
        { "type": "path", "url": "../../packages/tenancy-php", "options": { "symlink": true } }
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "jperdior/shared-kernel-php": "*",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.0",
        "gesdinet/jwt-refresh-token-bundle": "^1.4",
        "lexik/jwt-authentication-bundle": "^3.1",
        "nelmio/api-doc-bundle": "^5.10",
        "nelmio/cors-bundle": "^2.5",
        "predis/predis": "^2.0",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "qossmic/deptrac": "^2.0",
        "symfony/browser-kit": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true,
        "vendor-dir": "code/vendor"
    },
    "autoload": {
        "psr-4": {
            "App\\": "code/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "code/tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [ "@auto-scripts" ],
        "post-update-cmd":  [ "@auto-scripts" ]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*",
            "docker": false,
            "root-dir": "code"
        }
    }
}
