#!/bin/sh
set -e

cd /app/apps/api

mkdir -p var/cache var/log

# In dev, always install so dev deps (phpstan, cs-fixer, deptrac) are present even when
# the api_vendor named volume was seeded from the production image (--no-dev).
# In prod/test, only install when vendor is absent.
if [ "${APP_ENV:-prod}" = "dev" ] || [ ! -f vendor/autoload.php ]; then
  composer install --no-interaction --no-progress
fi

# Generate JWT keypair on first boot.
if [ ! -f config/jwt/private.pem ]; then
  php bin/console lexik:jwt:generate-keypair --skip-if-exists --no-interaction || true
fi

php bin/console cache:warmup || true
php bin/console doctrine:database:create --if-not-exists --no-interaction || true
php bin/console doctrine:migrations:migrate --no-interaction || true

# Dev only: seed a known admin (admin@example.com / !pw4template) so a fresh clone can
# reach the admin panel immediately. Idempotent (create-or-promote) and refuses to run in
# prod — never blocks boot.
if [ "${APP_ENV:-prod}" = "dev" ]; then
  php bin/console app:user:seed-admin || true
fi

exec frankenphp run --config /etc/frankenphp/Caddyfile
